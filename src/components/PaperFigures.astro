---
import { Image } from "astro:assets";
import type { PaperFigure } from "../data/research";

/**
 * Real figures from the paper's repository, optimized at build time.
 * Files live in src/assets/figures/<slug>/<file>.
 */
interface Props {
  slug: string;
  figures: PaperFigure[];
}

const { slug, figures } = Astro.props;

const all = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/figures/**/*.png",
  { eager: true },
);

const resolve = (file: string) => {
  const key = `/src/assets/figures/${slug}/${file}`;
  const mod = all[key];
  if (!mod) throw new Error(`Missing paper figure: ${key}`);
  return mod.default;
};
---

<section class="paperfigs container" aria-label="Figures from the paper">
  <p class="label-mono section-eyebrow" data-reveal>Figures from the paper</p>
  <div class="paperfigs-grid">
    {
      figures.map((f, i) => (
        <figure class="paperfig" data-reveal>
          <div class="paperfig-frame">
            <Image
              src={resolve(f.file)}
              alt={f.caption}
              widths={[720, 1200]}
              sizes="(max-width: 900px) 92vw, 60rem"
              format="webp"
              quality={82}
              loading="lazy"
            />
          </div>
          <figcaption class="paperfig-caption">
            <span class="label-mono paperfig-num">Fig. {i + 1}</span>
            <span>{f.caption}</span>
          </figcaption>
        </figure>
      ))
    }
  </div>
  <p class="label-mono paperfigs-note" data-reveal>
    Figures generated by the paper's own pipeline — reproducible from the repository.
  </p>
</section>

<style>
  .paperfigs {
    padding-block: var(--space-24);
    border-bottom: var(--rule);
  }

  .section-eyebrow {
    color: var(--signal);
    display: block;
    margin-bottom: var(--space-12);
  }

  .paperfigs-grid {
    display: grid;
    gap: var(--space-12);
    max-width: 60rem;
  }

  .paperfig { margin: 0; }

  .paperfig-frame {
    background: var(--paper-raised);
    border: var(--rule-strong);
    border-radius: var(--radius-2);
    padding: var(--space-6);
    transition: box-shadow var(--dur-med) var(--ease-out);
  }

  .paperfig:hover .paperfig-frame { box-shadow: var(--shadow-2); }

  .paperfig-frame img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-1);
  }

  .paperfig-caption {
    display: flex;
    gap: var(--space-4);
    align-items: baseline;
    margin-top: var(--space-4);
    color: var(--ink-2);
    font-size: var(--text-sm);
    max-width: 70ch;
  }

  .paperfig-num {
    color: var(--signal);
    flex-shrink: 0;
  }

  .paperfigs-note {
    margin-top: var(--space-12);
    color: var(--ink-3);
  }
</style>
