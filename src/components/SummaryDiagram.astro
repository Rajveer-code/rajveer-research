---
import type { SummaryDiagramSpec, Mark } from "../data/research";

/**
 * TrustShift-fig1-style verdict diagram: premise → probe → branch columns
 * (checklist + action) → punchline. Semantic tones carry meaning together
 * with ✓/✗ marks and labels — never color alone.
 */
interface Props {
  spec: SummaryDiagramSpec;
}

const { spec } = Astro.props;

const MARKS: Record<Mark, { glyph: string; cls: string }> = {
  check: { glyph: "✓", cls: "m-good" },
  x: { glyph: "✗", cls: "m-bad" },
  dash: { glyph: "—", cls: "m-dash" },
};
---

<figure class="sd" aria-label="Summary of the paper's argument">
  <div class="sd-premise">{spec.premise}</div>
  <svg class="sd-arrow" viewBox="0 0 16 22" aria-hidden="true">
    <line x1="8" y1="0" x2="8" y2="15" />
    <path d="M3 13 L8 20 L13 13" fill="none" />
  </svg>
  {spec.probe && <div class="sd-probe">{spec.probe}</div>}

  <div class="sd-branches" style={`--cols:${spec.branches.length}`}>
    {
      spec.branches.map((b) => (
        <div class={`sd-branch tone-${b.tone}`}>
          <div class="sd-head">
            <span class="sd-title">{b.title}</span>
            {b.sub && <span class="sd-sub">{b.sub}</span>}
          </div>
          <ul class="sd-rows">
            {b.rows.map((r) => (
              <li>
                <span class="sd-row-label">{r.label}</span>
                <span class={`sd-mark ${MARKS[r.mark].cls}`} aria-label={r.mark}>
                  {MARKS[r.mark].glyph}
                </span>
              </li>
            ))}
          </ul>
          <div class="sd-action">{b.action}</div>
          {b.tag && <span class="label-mono sd-tag">{b.tag}</span>}
        </div>
      ))
    }
  </div>

  <figcaption class="sd-punchline">{spec.punchline}</figcaption>
</figure>

<style>
  .sd {
    --t-bad: #b3421c;
    --t-warn: #a16207;
    --t-info: var(--signal);
    --t-good: var(--verified);
    margin: 0;
    padding: var(--space-8);
    background: var(--paper-raised);
    border: var(--rule-strong);
    border-radius: var(--radius-2);
    display: grid;
    justify-items: center;
    gap: var(--space-4);
  }

  .sd-premise {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-sm);
    text-align: center;
    padding: var(--space-3) var(--space-6);
    border: 1.5px solid var(--ink);
    border-radius: 999px;
    max-width: 46rem;
  }

  .sd-arrow {
    width: 1rem;
    height: 1.375rem;
    stroke: var(--hairline-strong);
    stroke-width: 1.5;
  }

  .sd-probe {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-sm);
    text-align: center;
    color: var(--paper);
    background: var(--signal);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-2);
    max-width: 44rem;
  }

  .sd-branches {
    display: grid;
    grid-template-columns: repeat(var(--cols), minmax(0, 1fr));
    gap: var(--space-4);
    width: 100%;
    margin-top: var(--space-4);
  }

  .sd-branch {
    display: grid;
    grid-template-rows: auto 1fr auto auto;
    gap: var(--space-3);
    justify-items: stretch;
  }

  .tone-bad { --tone: var(--t-bad); }
  .tone-warn { --tone: var(--t-warn); }
  .tone-info { --tone: var(--t-info); }
  .tone-good { --tone: var(--t-good); }

  .sd-head {
    background: var(--tone);
    color: #fff;
    border-radius: var(--radius-2);
    padding: var(--space-3) var(--space-4);
    text-align: center;
    display: grid;
    gap: var(--space-1);
  }

  .sd-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: var(--text-sm);
    letter-spacing: 0.01em;
  }

  .sd-sub {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-xs);
    opacity: 0.92;
  }

  .sd-rows {
    list-style: none;
    margin: 0;
    padding: var(--space-3) var(--space-4);
    border: 1.5px solid var(--tone);
    border-radius: var(--radius-2);
    display: grid;
    gap: var(--space-2);
    align-content: start;
  }

  .sd-rows li {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--ink-2);
  }

  .sd-mark { font-weight: 700; }
  .m-good { color: var(--verified); }
  .m-bad { color: #b3261e; }
  .m-dash { color: var(--ink-3); }

  .sd-action {
    background: var(--tone);
    color: #fff;
    border-radius: var(--radius-2);
    padding: var(--space-2) var(--space-3);
    text-align: center;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-xs);
    line-height: 1.4;
  }

  .sd-tag {
    justify-self: center;
    color: var(--ink-3);
  }

  .sd-punchline {
    margin-top: var(--space-6);
    padding-top: var(--space-4);
    border-top: var(--rule);
    width: 100%;
    text-align: center;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: var(--text-md);
    letter-spacing: var(--tracking-tight);
    color: var(--ink);
  }

  @media (max-width: 760px) {
    .sd-branches { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .sd-branches { grid-template-columns: 1fr; }
  }
</style>
