---
import { publications, THEME_LABELS, type Theme } from "../data/research";

interface Node {
  theme: Theme | null;
  label: string;
  x: number;
  y: number;
}

const CX = 450;
const CY = 260;

const nodes: Node[] = [
  { theme: "healthcare", label: THEME_LABELS["healthcare"], x: 150, y: 90 },
  { theme: "fairness", label: THEME_LABELS["fairness"], x: 450, y: 56 },
  { theme: "nlp-llm", label: THEME_LABELS["nlp-llm"], x: 750, y: 90 },
  { theme: "causal", label: THEME_LABELS["causal"], x: 108, y: 260 },
  { theme: "deployment", label: THEME_LABELS["deployment"], x: 792, y: 260 },
  { theme: "privacy", label: THEME_LABELS["privacy"], x: 150, y: 430 },
  { theme: "finance", label: THEME_LABELS["finance"], x: 450, y: 464 },
  { theme: "trustworthy-ml", label: "Audit & Evaluation", x: 750, y: 430 },
];

const countFor = (theme: Theme) =>
  publications.filter((p) => p.themes.includes(theme)).length;

const cross: [number, number][] = [
  [0, 5], // healthcare – privacy
  [1, 2], // fairness – nlp
  [3, 1], // causal – fairness
  [4, 6], // deployment – finance
  [2, 4], // nlp – deployment
];

// Papers per theme — drives the interactive detail panel.
const themeKeys = Object.keys(THEME_LABELS) as Theme[];
const papersByTheme = Object.fromEntries(
  themeKeys.map((t) => [
    t,
    publications
      .filter((p) => p.themes.includes(t))
      .sort((a, b) => a.order - b.order),
  ]),
) as Record<Theme, typeof publications>;
---

<section class="map-section" id="map">
  <div class="container">
    <p class="label-mono section-eyebrow" data-reveal>Research map</p>
    <h2 class="section-title" data-reveal>
      One ecosystem, <em>not</em> a list of results
    </h2>

    <p class="map-hint label-mono" data-reveal>
      Hover or tap a theme — TrustShift binds them all
    </p>
    <figure class="map-figure" data-reveal data-map-root>
      <svg
        class="map-svg"
        viewBox="20 24 860 472"
        role="img"
        aria-labelledby="map-desc"
        data-map
      >
        <desc id="map-desc">
          Network map: trustworthy machine learning at the center, connected to
          healthcare AI, fairness, NLP and LLMs, causal inference, deployment
          shift, privacy and federated learning, financial ML, and audit tooling.
        </desc>

        {/* edges: center → nodes */}
        {
          nodes.map((n, i) => (
            <line
              class="edge"
              x1={CX}
              y1={CY}
              x2={n.x}
              y2={n.y}
              data-edge
              data-edge-idx={i}
            />
          ))
        }
        {/* cross edges */}
        {
          cross.map(([a, b]) => (
            <line
              class="edge edge--cross"
              x1={nodes[a].x}
              y1={nodes[a].y}
              x2={nodes[b].x}
              y2={nodes[b].y}
              data-edge
            />
          ))
        }

        {/* satellite nodes — interactive */}
        {
          nodes.map((n, i) => (
            <g
              class="node"
              data-node
              data-node-idx={i}
              data-theme={n.theme}
              tabindex="0"
              role="button"
              aria-label={`${n.label} — ${n.theme ? countFor(n.theme) : 0} works`}
            >
              <circle cx={n.x} cy={n.y} r="16" class="node-hit" />
              <circle cx={n.x} cy={n.y} r="7" class="node-dot" />
              <text x={n.x} y={n.y - 18} class="node-label" text-anchor="middle">
                {n.label}
              </text>
              {n.theme && (
                <text x={n.x} y={n.y + 30} class="node-count" text-anchor="middle">
                  {countFor(n.theme)} {countFor(n.theme) === 1 ? "work" : "works"}
                </text>
              )}
            </g>
          ))
        }

        {/* center — the thesis; links to the flagship */}
        <a class="center" data-node href="/research/trustshift/" aria-label="TrustShift — the binding thesis">
          <circle cx={CX} cy={CY} r="72" class="center-pulse" />
          <circle cx={CX} cy={CY} r="72" class="center-ring" />
          <text x={CX} y={CY - 12} class="center-thesis" text-anchor="middle">
            Trust<tspan class="center-thesis--em">Shift</tspan>
          </text>
          <text x={CX} y={CY + 14} class="center-sub" text-anchor="middle">
            the thesis that
          </text>
          <text x={CX} y={CY + 32} class="center-sub" text-anchor="middle">
            binds every theme →
          </text>
        </a>
      </svg>

      <aside class="map-panel" data-map-panel aria-live="polite">
        <div class="panel-view" data-panel-default>
          <span class="label-mono panel-eyebrow">The thesis</span>
          <h3 class="panel-title">TrustShift binds the program</h3>
          <p class="panel-text">
            One pre-registered audit shows the <em>type</em> of deployment shift —
            not its magnitude — decides which axis of trustworthiness fails. Every
            theme around it is evidence that led here. Hover a node to see its work.
          </p>
          <a class="panel-cta ui-sans" href="/research/trustshift/">Open TrustShift →</a>
        </div>
        {
          themeKeys.map((t) => (
            <div class="panel-view" data-panel-theme={t} hidden>
              <span class="label-mono panel-eyebrow">{THEME_LABELS[t]}</span>
              <ul class="panel-list">
                {papersByTheme[t].map((p) => (
                  <li>
                    <a href={`/research/${p.slug}/`} class="panel-paper">
                      <span class="panel-paper-title">{p.shortTitle}</span>
                      <span class="ui-sans panel-paper-status">{p.status}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </aside>
    </figure>
  </div>
</section>

<script>
  function initResearchMap() {
    const root = document.querySelector<HTMLElement>("[data-map-root]");
    if (!root || root.dataset.wired) return;
    root.dataset.wired = "1";

    const views = root.querySelectorAll<HTMLElement>(".panel-view");
    const nodes = root.querySelectorAll<HTMLElement>("[data-theme]");
    let locked: string | null = null;

    const show = (theme: string | null) => {
      views.forEach((v) => {
        v.hidden = theme
          ? v.dataset.panelTheme !== theme
          : !("panelDefault" in v.dataset);
      });
    };

    nodes.forEach((node) => {
      const theme = node.dataset.theme ?? null;
      node.addEventListener("mouseenter", () => { if (!locked) show(theme); });
      node.addEventListener("mouseleave", () => { if (!locked) show(null); });
      node.addEventListener("focus", () => { if (!locked) show(theme); });
      node.addEventListener("blur", () => { if (!locked) show(null); });
      node.addEventListener("click", () => {
        locked = locked === theme ? null : theme;
        show(locked);
      });
      node.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          (node as HTMLElement).click();
        }
      });
    });
  }
  document.addEventListener("astro:page-load", initResearchMap);
</script>

<style>
  .map-section {
    padding-block: var(--space-section);
    border-bottom: var(--rule);
  }

  .section-eyebrow {
    color: var(--signal);
    display: block;
    margin-bottom: var(--space-8);
  }

  .section-title {
    font-weight: 460;
    max-width: 22ch;
    margin-bottom: var(--space-16);
  }

  .section-title em {
    font-style: italic;
    color: var(--signal);
  }

  .map-hint {
    color: var(--ink-3);
    margin-bottom: var(--space-6);
  }

  .map-figure {
    margin: 0;
  }

  .map-svg {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
    margin-inline: auto;
    max-width: 60rem;
  }

  /* --- interactive nodes --- */
  .node { cursor: pointer; outline: none; }
  .node-hit { fill: transparent; }
  .node:focus-visible .node-dot,
  .node:hover .node-dot {
    fill: var(--signal);
  }
  .node:focus-visible .node-label { fill: var(--signal); }
  .node:focus-visible .node-hit {
    stroke: var(--signal);
    stroke-width: 1.5;
    stroke-dasharray: 3 3;
  }
  .center { cursor: pointer; }

  .center-thesis {
    font-family: var(--font-serif);
    font-size: 26px;
    fill: var(--signal-deep);
    font-weight: 500;
  }
  .center-thesis--em { font-style: italic; fill: var(--signal); }

  .center-sub {
    font-family: var(--font-sans);
    font-size: 12.5px;
    fill: var(--signal-deep);
  }
  .center:hover .center-ring { fill: color-mix(in srgb, var(--signal) 16%, var(--paper)); }

  /* --- detail panel (full-width strip below the map) --- */
  .map-panel {
    min-height: 9rem;
    margin-top: var(--space-8);
    padding: var(--space-8);
    border: var(--rule-strong);
    border-radius: var(--radius-2);
    background: var(--paper-raised);
  }

  .panel-eyebrow { color: var(--signal); display: block; margin-bottom: var(--space-4); }

  .panel-title {
    font-size: var(--text-lg);
    font-weight: 500;
    margin-bottom: var(--space-4);
  }

  .panel-text { color: var(--ink-2); max-width: 70ch; }
  .panel-text em { font-style: italic; color: var(--signal); }

  .panel-cta {
    display: inline-block;
    margin-top: var(--space-6);
    color: var(--signal);
    text-decoration: none;
  }
  .panel-cta:hover { text-decoration: underline; }

  .panel-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: var(--space-2) var(--space-8);
  }

  .panel-paper {
    display: grid;
    gap: 2px;
    padding-block: var(--space-3);
    border-bottom: var(--rule);
    text-decoration: none;
    color: var(--ink);
  }
  .panel-paper:hover .panel-paper-title { color: var(--signal); }

  .panel-paper-title {
    font-size: var(--text-base);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .panel-paper-status { font-size: var(--text-xs); color: var(--ink-3); }

  @media (max-width: 860px) {
    .map-figure { grid-template-columns: 1fr; gap: var(--space-8); }
  }

  .edge {
    stroke: var(--hairline-strong);
    stroke-width: 1;
  }

  .edge--cross {
    stroke-dasharray: 4 5;
    stroke: var(--hairline-strong);
  }

  .node-dot {
    fill: var(--paper);
    stroke: var(--signal);
    stroke-width: 2;
  }

  .node-label {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 600;
    fill: var(--ink);
  }

  .node-count {
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.06em;
    fill: var(--ink-3);
  }

  .center-ring {
    fill: var(--signal-wash);
    stroke: var(--signal);
    stroke-width: 1.5;
  }

  .center-pulse {
    fill: none;
    stroke: var(--signal);
    stroke-width: 1;
    transform-origin: 450px 260px;
    animation: map-pulse 4.5s var(--ease-out) infinite;
  }

  @keyframes map-pulse {
    0% { transform: scale(1); opacity: 0.55; }
    70%, 100% { transform: scale(1.55); opacity: 0; }
  }

  /* hover spotlight: dim everything, light the hovered spoke */
  .edge, .node { transition: opacity var(--dur-med) var(--ease-out); }

  .map-svg.is-hover :is(.edge, .node):not(.is-hot) { opacity: 0.22; }
  .map-svg.is-hover .center { opacity: 1; }

  .edge.is-hot {
    stroke: var(--signal);
    stroke-width: 1.5;
  }

  .node.is-hot .node-dot { fill: var(--signal-wash); }

  .center-dot { fill: var(--signal); }

  .center-label {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 19px;
    fill: var(--signal-deep);
  }

  .map-caption {
    margin-top: var(--space-8);
    max-width: 60ch;
  }

  @media (max-width: 640px) {
    .node-label { font-size: 19px; }
    .node-count { font-size: 14px; }
    .center-label { font-size: 22px; }
  }
</style>
