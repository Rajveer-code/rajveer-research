---
const links = [
  { label: "Research", href: "/#research" },
  { label: "Publications", href: "/#publications" },
  { label: "Open Science", href: "/#open-science" },
  { label: "Contact", href: "/#contact" },
];
---

<nav class="nav" aria-label="Primary">
  <div class="nav-inner container container--wide">
    <a class="wordmark" href="/">
      <span class="wordmark-name">Rajveer Singh Pall</span>
      <span class="label-mono wordmark-sub">AI Research</span>
    </a>
    <div class="nav-links ui-sans">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: var(--rule);
    transition: transform var(--dur-med) var(--ease-inout);
  }

  .nav:global(.nav--hidden) { transform: translateY(-100%); }

  .nav-links a:global(.is-active) {
    color: var(--signal);
  }

  .nav-inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-4);
  }

  .wordmark {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--ink);
  }

  .wordmark-name {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    font-weight: 500;
    letter-spacing: var(--tracking-tight);
  }

  .wordmark-sub { color: var(--signal); }

  .nav-links {
    display: flex;
    gap: var(--space-6);
  }

  .nav-links a {
    color: var(--ink-2);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .nav-links a:hover { color: var(--signal); }

  @media (max-width: 640px) {
    .wordmark-sub { display: none; }
    .nav-inner {
      flex-wrap: wrap;
      row-gap: var(--space-1);
      padding-block: var(--space-3);
    }
    .wordmark-name {
      font-size: var(--text-base);
      white-space: nowrap;
    }
    .nav-links {
      gap: var(--space-4);
      flex-wrap: wrap;
      font-size: var(--text-xs);
    }
  }
</style>
