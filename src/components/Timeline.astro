---
import { timeline } from "../data/research";
---

<section class="timeline-section container" id="timeline">
  <p class="label-mono section-eyebrow" data-reveal>Research trajectory</p>
  <h2 class="section-title" data-reveal>
    Every question was <em>earned</em> by the one before it
  </h2>

  <ol class="timeline" data-timeline>
    <div class="spine" aria-hidden="true"><div class="spine-progress"></div></div>
    {
      timeline.map((t) => (
        <li class="entry" data-reveal>
          <span class="entry-marker" aria-hidden="true" />
          <div class="entry-head">
            <span class="label-mono entry-period">{t.period}</span>
            <span class="label-mono entry-theme">{t.theme}</span>
          </div>
          <p class="entry-question">{t.question}</p>
          <h3 class="entry-title">
            {t.slug ? <a href={`/research/${t.slug}/`}>{t.title}</a> : t.title}
          </h3>
          <p class="entry-text">{t.text}</p>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .timeline-section {
    padding-block: var(--space-section);
    border-bottom: var(--rule);
  }

  .section-eyebrow {
    color: var(--signal);
    display: block;
    margin-bottom: var(--space-8);
  }

  .section-title {
    font-weight: 460;
    max-width: 22ch;
    margin-bottom: var(--space-24);
  }

  .section-title em {
    font-style: italic;
    color: var(--signal);
  }

  .timeline {
    list-style: none;
    position: relative;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-16);
    max-width: 46rem;
  }

  .spine {
    position: absolute;
    left: 0.3125rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 1px;
    background: var(--hairline-strong);
  }

  .spine-progress {
    width: 100%;
    height: 100%;
    background: var(--signal);
    transform-origin: top;
    transform: scaleY(0);
  }

  .entry {
    position: relative;
    padding-left: var(--space-8);
  }

  .entry-marker {
    position: absolute;
    left: 0;
    top: 0.45rem;
    width: 0.6875rem;
    height: 0.6875rem;
    border-radius: 50%;
    background: var(--paper);
    border: 2px solid var(--signal);
  }

  .entry-head {
    display: flex;
    gap: var(--space-6);
    margin-bottom: var(--space-2);
  }

  .entry-period { color: var(--signal); }

  .entry-question {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-md);
    color: var(--signal);
    margin-bottom: var(--space-2);
    max-width: 40ch;
  }

  .entry-title {
    font-size: var(--text-lg);
    font-weight: 500;
    margin-bottom: var(--space-3);
  }

  .entry-title a {
    color: inherit;
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .entry-title a:hover { color: var(--signal); }

  .entry-text { color: var(--ink-2); }
</style>
