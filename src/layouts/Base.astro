---
import { ClientRouter } from "astro:transitions";
import "@fontsource-variable/newsreader";
import "@fontsource-variable/newsreader/wght-italic.css";
import "@fontsource-variable/instrument-sans";
import "@fontsource/fragment-mono";
import "../styles/tokens.css";
import "../styles/base.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Rajveer Singh Pall — AI researcher studying trustworthy machine learning under real-world deployment: fairness, calibration, external validation, and deployment-shift auditing.",
} = Astro.props;

// Absolute URLs for crawlers/social; fall back to relative if `site` is unset.
const ogImage = Astro.site ? new URL("/og.png", Astro.site).href : "/og.png";
const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.pathname;

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Rajveer Singh Pall",
  jobTitle: "AI Researcher",
  description:
    "Researcher in trustworthy machine learning under real-world deployment.",
  email: "mailto:rajveerpall04@gmail.com",
  sameAs: [
    "https://github.com/Rajveer-code",
    "https://huggingface.co/Rajveer-code",
    "https://orcid.org/0009-0001-6762-6134",
    "https://scholar.google.com/citations?hl=en&user=47CvVCcAAAAJ",
    "https://www.linkedin.com/in/rajveer-singh-pall/",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Rajveer Singh Pall" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Rajveer Singh Pall — AI Research" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <ClientRouter />
  </head>
  <body>
    <canvas class="site-field" id="site-field" aria-hidden="true" transition:persist
    ></canvas>
    <slot />
    <script>
      import { initMotion, cleanupMotion } from "../scripts/motion";
      // run now (astro:page-load may already have fired in dev) and after
      // every view transition; initMotion cleans up before re-running
      initMotion();
      document.addEventListener("astro:page-load", initMotion);
      document.addEventListener("astro:before-swap", cleanupMotion);
    </script>
  </body>
</html>
