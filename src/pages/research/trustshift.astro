---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import { publications, THEME_LABELS } from "../../data/research";

/**
 * Extended flagship page. Every number below is copied verbatim from
 * D:\Projects\trustshift\paper\numbers.json (regenerated by run_all.py) —
 * never from memory. Values shown at 3 dp as stored.
 */

const pub = publications.find((p) => p.slug === "trustshift")!;

const related = publications
  .filter((p) => p.slug !== pub.slug && p.themes.some((t) => pub.themes.includes(t)))
  .sort((a, b) => a.order - b.order)
  .slice(0, 3);

const fiveMinute = [
  { label: "Problem", text: pub.problem },
  { label: "Approach", text: pub.approach },
  { label: "Findings", text: pub.findings },
  { label: "Why it matters", text: pub.matters },
];

// numbers.json → domain evidence
const domains = [
  {
    name: "Clinical",
    shift: "NHANES → BRFSS",
    aucSrc: 0.788,
    aucTgt: 0.757,
    facts: [
      { k: "ΔAUC", v: "−0.031" },
      { k: "ECE", v: "0.168 → 0.276" },
      { k: "Subgroup gap Δ", v: "−0.066 [−0.113, −0.016], p = 0.011" },
    ],
    note: "Discrimination barely moves; calibration and the age-subgroup gap take the hit.",
  },
  {
    name: "Mental-health NLP",
    shift: "Kaggle → Reddit · Twitter",
    aucSrc: 0.985,
    aucTgt: 0.65,
    facts: [
      { k: "AUC", v: "0.983–0.987 → 0.596–0.703" },
      { k: "ΔAUC", v: "0.282–0.388" },
      { k: "Target ECE", v: "0.100–0.275" },
    ],
    note: "Every axis degrades at once — the worst-case shift signature.",
  },
  {
    name: "Lending",
    shift: "HMDA temporal · geographic",
    aucSrc: 0.805,
    aucTgt: 0.821,
    facts: [
      { k: "ΔAUC (temporal)", v: "−0.028 … −0.012 (improves)" },
      { k: "Domain-classifier AUC", v: "0.688–0.804 — shift clearly present" },
      { k: "Pre-recalibration ECE", v: "≈ 0.24" },
    ],
    note: "The counter-example: large detectable shift, intact discrimination — magnitude is not damage. Only calibration fails.",
  },
  {
    name: "Network security",
    shift: "CIC-DDoS2019 → CICIDS2017",
    aucSrc: 1.0,
    aucTgt: 0.635,
    facts: [
      { k: "AUC", v: "1.000 → 0.635" },
      { k: "ECE", v: "0.001 → 0.451" },
      { k: "Unseen-family recall", v: "0.052 – 0.355" },
    ],
    note: "New attack families the model never saw: discrimination collapses outright.",
  },
];

// numbers.json → remediation (isotonic recalibration, label-cheap)
const remediation = [
  { target: "Clinical → BRFSS", eceB: 0.276, eceA: 0.002, aucB: 0.757, aucA: 0.757 },
  { target: "NLP → Reddit", eceB: 0.115, eceA: 0.016, aucB: 0.648, aucA: 0.636 },
  { target: "NLP → Twitter", eceB: 0.254, eceA: 0.055, aucB: 0.592, aucA: 0.589 },
  { target: "Lending → 2022", eceB: 0.246, eceA: 0.006, aucB: 0.805, aucA: 0.805 },
  { target: "Lending → 2023", eceB: 0.24, eceA: 0.002, aucB: 0.821, aucA: 0.821 },
  { target: "Lending → 2024", eceB: 0.241, eceA: 0.006, aucB: 0.819, aucA: 0.819 },
  { target: "Security → CICIDS2017", eceB: 0.45, eceA: 0.013, aucB: 0.634, aucA: 0.708 },
];

// numbers.json → meta-analysis
const meta = [
  {
    id: "M1",
    label: "Trust-gap vs calibration degradation",
    slope: "0.415",
    ci: "[0.169, 0.603]",
    r2: "0.414",
    n: "14",
  },
  {
    id: "M2",
    label: "Trust-gap vs covariate-shift probe",
    slope: "0.536",
    ci: "[0.347, 0.843]",
    r2: "0.771",
    n: "11",
  },
  {
    id: "M3",
    label: "Trust-gap vs accuracy loss",
    slope: "0.344",
    ci: "[0.271, 0.435]",
    r2: "0.818",
    n: "14",
  },
];

const fmt = (n: number) => n.toFixed(3);
---

<Base title={`TrustShift — Rajveer Singh Pall`} description={pub.oneLiner}>
  <Nav />
  <main>
    <article>
      <header class="paper-head container">
        <p class="label-mono breadcrumb">
          <a href="/#publications">Publications</a> / TrustShift
        </p>
        <div class="paper-meta">
          <span class="status status--review">{pub.status}</span>
          <span class="label-mono">{pub.year}</span>
        </div>
        <h1 class="paper-title" data-hero="1">{pub.title}</h1>
        <p class="paper-authors ui-sans" data-hero="2">{pub.authors}</p>
        <p class="paper-oneliner" data-hero="3">{pub.oneLiner}</p>
        <div class="paper-links ui-sans" data-hero="4">
          {pub.links.map((l) => <a class="btn" href={l.href}>{l.label} ↗</a>)}
        </div>
      </header>

      <section class="five container" aria-label="The paper in five minutes">
        <p class="label-mono section-eyebrow" data-reveal>In five minutes</p>
        <ol class="five-list">
          {
            fiveMinute.map((block, i) => (
              <li class="five-block" data-reveal>
                <span class="label-mono five-index">{String(i + 1).padStart(2, "0")}</span>
                <h2 class="five-label">{block.label}</h2>
                <p class="five-text">{block.text}</p>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="domains container" aria-label="Evidence by domain">
        <p class="label-mono section-eyebrow" data-reveal>The evidence, domain by domain</p>
        <p class="section-lead" data-reveal>
          Same protocol, four worlds. If magnitude determined damage, the biggest
          shifts would always hurt most. They don't — the <em>kind</em> of shift
          decides which axis breaks.
        </p>
        <ul class="domain-grid">
          {
            domains.map((d) => (
              <li class="domain-card" data-reveal>
                <div class="domain-head">
                  <h3 class="domain-name">{d.name}</h3>
                  <span class="label-mono domain-shift">{d.shift}</span>
                </div>
                <div class="auc-bars" aria-label={`AUC before and after shift, ${d.name}`}>
                  <div class="auc-row">
                    <span class="label-mono auc-label">source</span>
                    <div class="bar-track">
                      <div class="bar bar--src" style={`width:${d.aucSrc * 100}%`} />
                    </div>
                    <code class="auc-value">{fmt(d.aucSrc)}</code>
                  </div>
                  <div class="auc-row">
                    <span class="label-mono auc-label">target</span>
                    <div class="bar-track">
                      <div class="bar bar--tgt" style={`width:${d.aucTgt * 100}%`} />
                    </div>
                    <code class="auc-value">{fmt(d.aucTgt)}</code>
                  </div>
                </div>
                <dl class="domain-facts">
                  {d.facts.map((f) => (
                    <div class="fact-row">
                      <dt class="label-mono">{f.k}</dt>
                      <dd>
                        <code>{f.v}</code>
                      </dd>
                    </div>
                  ))}
                </dl>
                <p class="domain-note">{d.note}</p>
              </li>
            ))
          }
        </ul>
        <p class="label-mono trace-note" data-reveal>
          All values verbatim from results JSONs regenerated by run_all.py — see repository.
        </p>
      </section>

      <section class="remediation container" aria-label="Remediation experiment">
        <p class="label-mono section-eyebrow" data-reveal>What a label-cheap fix can — and cannot — repair</p>
        <p class="section-lead" data-reveal>
          Isotonic recalibration on a small calibration split. Toggle it: calibration
          error is repaired everywhere; discrimination almost never moves.
        </p>
        <div class="remed" data-reveal data-remed data-state="before">
          <div class="remed-toggle ui-sans" role="group" aria-label="Recalibration toggle">
            <button class="remed-btn is-active" data-set="before" type="button">
              Before recalibration
            </button>
            <button class="remed-btn" data-set="after" type="button">
              After isotonic recalibration
            </button>
          </div>
          <table class="remed-table">
            <thead>
              <tr>
                <th scope="col" class="label-mono">Domain → target</th>
                <th scope="col" class="label-mono">ECE</th>
                <th scope="col" class="label-mono">AUC</th>
              </tr>
            </thead>
            <tbody>
              {
                remediation.map((r) => (
                  <tr>
                    <th scope="row">{r.target}</th>
                    <td>
                      <div class="cell-bar">
                        <code
                          class="remed-value"
                          data-before={fmt(r.eceB)}
                          data-after={fmt(r.eceA)}
                        >
                          {fmt(r.eceB)}
                        </code>
                        <div class="bar-track bar-track--cell">
                          <div
                            class="bar bar--ece"
                            data-wbefore={`${Math.min(r.eceB * 200, 100)}%`}
                            data-wafter={`${Math.min(r.eceA * 200, 100)}%`}
                            style={`width:${Math.min(r.eceB * 200, 100)}%`}
                          />
                        </div>
                      </div>
                    </td>
                    <td>
                      <code
                        class="remed-value"
                        data-before={fmt(r.aucB)}
                        data-after={fmt(r.aucA)}
                      >
                        {fmt(r.aucB)}
                      </code>
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
          <p class="remed-punchline">
            <span class="label-mono">Read:</span> calibration failure is cheap to fix
            without labels. Discrimination failure is not — except security's partial
            recovery (0.634 → 0.708), the exception that proves the taxonomy.
          </p>
        </div>
      </section>

      <section class="meta container" aria-label="Cross-domain meta-analysis" data-reveal>
        <p class="label-mono section-eyebrow">Cross-domain meta-analysis</p>
        <p class="section-lead">
          Sixteen shift points across the four domains. Each regression relates the
          deployment trust-gap to a different explanation — against each domain's own
          baseline, never raw cross-domain magnitude.
        </p>
        <ul class="meta-list">
          {
            meta.map((m) => (
              <li class="meta-row">
                <span class="label-mono meta-id">{m.id}</span>
                <span class="meta-label">{m.label}</span>
                <code class="meta-stat">slope {m.slope} {m.ci}</code>
                <code class="meta-stat">R² {m.r2} · n {m.n}</code>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="repro container" aria-label="Reproduce this paper" data-reveal>
        <p class="label-mono section-eyebrow">Reproduce it</p>
        <div class="repro-grid">
          <pre class="repro-code"><code>git clone https://github.com/Rajveer-code/trustshift
cd trustshift
pip install -r requirements.txt
python run_all.py   # regenerates every table and figure</code></pre>
          <p class="repro-text">
            A fresh-clone reproduction of the master table was verified
            byte-identical, and the full pipeline re-run completed with exit 0.
            Prediction parquets and result JSONs are mirrored on
            <a href="https://huggingface.co/datasets/Rajveer-code/trustshift">Hugging Face</a>.
          </p>
        </div>
      </section>

      <section class="cite container" data-reveal aria-label="Themes and citation">
        <div class="cite-grid">
          <div>
            <p class="label-mono section-eyebrow">Themes</p>
            <ul class="theme-list">
              {pub.themes.map((t) => <li class="label-mono">{THEME_LABELS[t]}</li>)}
            </ul>
          </div>
          <div>
            <p class="label-mono section-eyebrow">Citation</p>
            <p class="cite-note">
              Manuscript under review — citation will be posted on acceptance.
              Reach me at <a href="mailto:rajveerpall04@gmail.com">rajveerpall04@gmail.com</a>.
            </p>
          </div>
        </div>
      </section>

      <section class="related container" data-reveal aria-label="Related research">
        <p class="label-mono section-eyebrow">The work TrustShift binds together</p>
        <ul class="related-list">
          {
            related.map((r) => (
              <li>
                <a href={`/research/${r.slug}/`} class="related-link">
                  <span class="related-title">{r.shortTitle}</span>
                  <span class="ui-sans related-status">{r.status}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </article>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <a class="label-mono back" href="/#publications">← All publications</a>
      <span class="label-mono">© 2026 Rajveer Singh Pall</span>
    </div>
  </footer>
</Base>

<script>
  document.querySelectorAll<HTMLElement>("[data-remed]").forEach((root) => {
    const buttons = root.querySelectorAll<HTMLButtonElement>(".remed-btn");
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const state = btn.dataset.set as "before" | "after";
        root.dataset.state = state;
        buttons.forEach((b) => b.classList.toggle("is-active", b === btn));
        root.querySelectorAll<HTMLElement>(".remed-value").forEach((v) => {
          v.textContent = state === "before" ? v.dataset.before! : v.dataset.after!;
        });
        root.querySelectorAll<HTMLElement>(".bar--ece").forEach((bar) => {
          bar.style.width =
            state === "before" ? bar.dataset.wbefore! : bar.dataset.wafter!;
        });
      });
    });
  });
</script>

<style>
  .paper-head {
    padding-block: var(--space-24) var(--space-16);
    border-bottom: var(--rule);
  }

  .breadcrumb { display: block; margin-bottom: var(--space-12); }
  .breadcrumb a { color: var(--ink-3); text-decoration: none; }
  .breadcrumb a:hover { color: var(--signal); }

  .paper-meta {
    display: flex;
    gap: var(--space-4);
    align-items: baseline;
    margin-bottom: var(--space-6);
  }

  .status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-1);
  }

  .status--review { background: var(--signal-wash); color: var(--signal-deep); }

  .paper-title {
    font-size: var(--text-xl);
    font-weight: 460;
    max-width: 30ch;
    margin-bottom: var(--space-6);
  }

  .paper-authors { color: var(--ink-3); margin-bottom: var(--space-4); }

  .paper-oneliner {
    font-size: var(--text-md);
    line-height: var(--leading-snug);
    color: var(--ink-2);
    max-width: 52ch;
  }

  .paper-links {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-8);
  }

  .btn {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    border: 1px solid var(--hairline-strong);
    border-radius: var(--radius-2);
    color: var(--ink);
    text-decoration: none;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  .btn:hover { border-color: var(--signal); color: var(--signal); }

  .section-eyebrow {
    color: var(--signal);
    display: block;
    margin-bottom: var(--space-8);
  }

  .section-lead {
    color: var(--ink-2);
    max-width: 58ch;
    margin-bottom: var(--space-12);
  }

  .section-lead em { font-style: italic; color: var(--signal); }

  .five { padding-block: var(--space-24); border-bottom: var(--rule); }

  .five-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12) var(--space-16);
  }

  .five-block { display: grid; gap: var(--space-3); align-content: start; }
  .five-index { color: var(--signal); }
  .five-label { font-size: var(--text-md); font-style: italic; font-weight: 500; }
  .five-text { color: var(--ink-2); }

  /* ---- domains ---- */
  .domains { padding-block: var(--space-24); border-bottom: var(--rule); }

  .domain-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  .domain-card {
    padding: var(--space-6);
    border: var(--rule-strong);
    border-radius: var(--radius-2);
    background: var(--paper-raised);
    display: grid;
    gap: var(--space-4);
    align-content: start;
  }

  .domain-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
  }

  .domain-name { font-size: var(--text-md); font-weight: 500; }
  .domain-shift { color: var(--signal); }

  .auc-bars { display: grid; gap: var(--space-2); }

  .auc-row {
    display: grid;
    grid-template-columns: 3.5rem 1fr 3.5rem;
    gap: var(--space-3);
    align-items: center;
  }

  .auc-label { color: var(--ink-3); }

  .bar-track {
    height: 0.5rem;
    background: var(--paper-recessed);
    border-radius: var(--radius-1);
    overflow: hidden;
  }

  .bar {
    height: 100%;
    border-radius: var(--radius-1);
    transition: width var(--dur-slow) var(--ease-inout);
  }

  .bar--src { background: var(--hairline-strong); }
  .bar--tgt { background: var(--signal); }
  .bar--ece { background: var(--signal); }

  .auc-value { font-size: var(--text-xs); color: var(--ink-2); }

  .domain-facts { margin: 0; display: grid; gap: var(--space-2); }

  .fact-row {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: var(--rule);
  }

  .fact-row dt { color: var(--ink-3); }
  .fact-row dd { margin: 0; text-align: right; }
  .fact-row code { font-size: var(--text-xs); }

  .domain-note {
    font-style: italic;
    color: var(--ink-2);
    font-size: var(--text-sm);
  }

  .trace-note { margin-top: var(--space-8); color: var(--ink-3); }

  /* ---- remediation ---- */
  .remediation { padding-block: var(--space-24); border-bottom: var(--rule); }

  .remed-toggle {
    display: inline-flex;
    border: var(--rule-strong);
    border-radius: var(--radius-2);
    overflow: hidden;
    margin-bottom: var(--space-8);
  }

  .remed-btn {
    padding: var(--space-3) var(--space-6);
    background: var(--paper-raised);
    border: none;
    color: var(--ink-2);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }

  .remed-btn + .remed-btn { border-left: var(--rule-strong); }

  .remed-btn.is-active {
    background: var(--ink);
    color: var(--paper);
  }

  .remed-table {
    width: 100%;
    border-collapse: collapse;
  }

  .remed-table th,
  .remed-table td {
    text-align: left;
    padding: var(--space-3) var(--space-4) var(--space-3) 0;
    border-bottom: var(--rule);
    font-weight: 400;
  }

  .remed-table thead th { color: var(--ink-3); }

  .remed-table tbody th {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
  }

  .cell-bar {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: var(--space-3);
    align-items: center;
    max-width: 18rem;
  }

  .bar-track--cell { height: 0.375rem; }

  .remed-value { font-size: var(--text-sm); }

  .remed-punchline {
    margin-top: var(--space-8);
    color: var(--ink-2);
    max-width: 70ch;
  }

  .remed-punchline .label-mono { color: var(--signal); margin-right: var(--space-2); }

  /* ---- meta ---- */
  .meta { padding-block: var(--space-24); border-bottom: var(--rule); }

  .meta-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 2px solid var(--ink);
  }

  .meta-row {
    display: grid;
    grid-template-columns: 3rem 1fr auto auto;
    gap: var(--space-6);
    align-items: baseline;
    padding-block: var(--space-4);
    border-bottom: var(--rule);
  }

  .meta-id { color: var(--signal); }
  .meta-stat { font-size: var(--text-sm); color: var(--ink-2); }

  /* ---- repro ---- */
  .repro { padding-block: var(--space-24); border-bottom: var(--rule); }

  .repro-grid {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: var(--space-12);
    align-items: start;
  }

  .repro-code {
    background: var(--ink);
    color: var(--paper);
    padding: var(--space-6);
    border-radius: var(--radius-2);
    overflow-x: auto;
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  .repro-text { color: var(--ink-2); }

  /* ---- cite / related / footer ---- */
  .cite { padding-block: var(--space-24); border-bottom: var(--rule); }

  .cite-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-16); }

  .theme-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .cite-note { color: var(--ink-2); }

  .related { padding-block: var(--space-24); }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 2px solid var(--ink);
  }

  .related-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    padding-block: var(--space-4);
    border-bottom: var(--rule);
    text-decoration: none;
    color: var(--ink);
  }

  .related-link:hover .related-title { color: var(--signal); }
  .related-title { font-size: var(--text-md); transition: color var(--dur-fast) var(--ease-out); }
  .related-status { color: var(--ink-3); }

  .footer { border-top: var(--rule); background: var(--paper-recessed); }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-8);
  }

