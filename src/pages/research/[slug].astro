---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import MethodFlow from "../../components/MethodFlow.astro";
import FigureBars from "../../components/FigureBars.astro";
import PaperFigures from "../../components/PaperFigures.astro";
import HeroFigure from "../../components/HeroFigure.astro";
import { publications, THEME_LABELS } from "../../data/research";

export function getStaticPaths() {
  // trustshift has a dedicated extended page (trustshift.astro)
  return publications
    .filter((p) => p.slug !== "trustshift")
    .map((p) => ({ params: { slug: p.slug }, props: { pub: p } }));
}

const { pub } = Astro.props;

const related = publications
  .filter((p) => p.slug !== pub.slug && p.themes.some((t) => pub.themes.includes(t)))
  .sort((a, b) => a.order - b.order)
  .slice(0, 3);

const fiveMinute = [
  { label: "Problem", text: pub.problem },
  { label: "Approach", text: pub.approach },
  { label: "Findings", text: pub.findings },
  { label: "Why it matters", text: pub.matters },
];
---

<Base title={`${pub.shortTitle} — Rajveer Singh Pall`} description={pub.oneLiner}>
  <Nav />
  <main>
    <article>
      <header class="paper-head container">
        <p class="label-mono breadcrumb">
          <a href="/#publications">Publications</a> / {pub.shortTitle}
        </p>
        <div class="paper-meta">
          <span class={`status status--${pub.statusKind}`}>{pub.status}</span>
          <span class="label-mono">{pub.year}</span>
        </div>
        <h1 class="paper-title" data-hero="1">{pub.title}</h1>
        <p class="paper-authors ui-sans" data-hero="2">{pub.authors}</p>
        <p class="paper-oneliner" data-hero="3">{pub.oneLiner}</p>
        {
          pub.links.length > 0 && (
            <div class="paper-links ui-sans" data-hero="4">
              {pub.links.map((l) => (
                <a class="btn" href={l.href}>
                  {l.label} ↗
                </a>
              ))}
            </div>
          )
        }
      </header>

      <nav class="paper-jump" aria-label="On this page" data-paper-jump>
        <div class="container paper-jump-inner ui-sans">
          <a href="#overview">Overview</a>
          <a href="#method">Method</a>
          <a href="#figure">Key figure</a>
          <a href="#summary">In 5 minutes</a>
          <a href="#results">Results</a>
        </div>
      </nav>

      <section class="plain container" id="overview" aria-label="Plain-language summary" data-reveal>
        <p class="label-mono section-eyebrow">Starting from zero</p>
        <p class="plain-text">{pub.plain}</p>
      </section>

      <section class="method container" id="method" aria-label="How the study works">
        <p class="label-mono section-eyebrow" data-reveal>How it works</p>
        <div class="method-grid" data-reveal>
          <MethodFlow steps={pub.flow} />
          {
            pub.figures.length > 0 && (
              <div class="method-figs">
                {pub.figures.map((f) => (
                  <FigureBars figure={f} />
                ))}
              </div>
            )
          }
        </div>
      </section>

      <section class="onefig container" id="figure" aria-label="The discovery in one figure">
        <p class="label-mono section-eyebrow" data-reveal>The discovery in one figure</p>
        <div data-reveal>
          <HeroFigure slug={pub.slug} />
        </div>
      </section>

      {
        pub.paperFigures && pub.paperFigures.length > 0 && (
          <PaperFigures slug={pub.slug} figures={pub.paperFigures} />
        )
      }

      <section class="five container" id="summary" aria-label="The paper in five minutes">
        <p class="label-mono section-eyebrow" data-reveal>In five minutes</p>
        <ol class="five-list">
          {
            fiveMinute.map((block, i) => (
              <li class="five-block" data-reveal>
                <span class="label-mono five-index">{String(i + 1).padStart(2, "0")}</span>
                <h2 class="five-label">{block.label}</h2>
                <p class="five-text">{block.text}</p>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="results container" id="results" data-reveal aria-label="Key results">
        <p class="label-mono section-eyebrow">Key results</p>
        <ul class="results-grid">
          {
            pub.results.map((r) => (
              <li>
                <span class="result-value">{r.value}</span>
                <span class="result-label">{r.label}</span>
              </li>
            ))
          }
        </ul>
        {pub.caveat && (
          <p class="caveat">
            <span class="label-mono caveat-tag">Stated honestly</span>
            {pub.caveat}
          </p>
        )}
      </section>

      <section class="cite container" data-reveal aria-label="Themes and citation">
        <div class="cite-grid">
          <div>
            <p class="label-mono section-eyebrow">Themes</p>
            <ul class="theme-list">
              {pub.themes.map((t) => <li class="label-mono">{THEME_LABELS[t]}</li>)}
            </ul>
          </div>
          <div>
            <p class="label-mono section-eyebrow">Citation</p>
            <p class="cite-note">
              {
                pub.statusKind === "presented"
                  ? "Presented work — formal citation available on request. "
                  : pub.statusKind === "working"
                    ? "Working paper — draft and citation available on request. "
                    : "Manuscript under review — citation will be posted on acceptance. "
              }
              Reach me at <a href="mailto:rajveerpall04@gmail.com">rajveerpall04@gmail.com</a>.
            </p>
          </div>
        </div>
      </section>

      {
        related.length > 0 && (
          <section class="related container" data-reveal aria-label="Related research">
            <p class="label-mono section-eyebrow">Related research</p>
            <ul class="related-list">
              {related.map((r) => (
                <li>
                  <a href={`/research/${r.slug}/`} class="related-link">
                    <span class="related-title">{r.shortTitle}</span>
                    <span class="ui-sans related-status">{r.status}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </article>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <a class="label-mono back" href="/#publications">← All publications</a>
      <span class="label-mono">© 2026 Rajveer Singh Pall</span>
    </div>
  </footer>
</Base>

<script>
  function initPaperJump() {
    const nav = document.querySelector("[data-paper-jump]");
    if (!nav) return;
    const links = [...nav.querySelectorAll("a")];
    const byId = new Map(
      links.map((a) => [a.getAttribute("href")!.slice(1), a]),
    );
    const sections = [...byId.keys()]
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => !!el);
    if (!sections.length) return;
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            links.forEach((l) => l.classList.remove("is-active"));
            byId.get((e.target as HTMLElement).id)?.classList.add("is-active");
          }
        });
      },
      { rootMargin: "-40% 0px -55% 0px" },
    );
    sections.forEach((s) => io.observe(s));
  }
  document.addEventListener("astro:page-load", initPaperJump);
</script>

<style>
  /* sticky in-page jump nav — helps professors skim */
  .paper-jump {
    position: sticky;
    top: 0;
    z-index: 95;
    background: color-mix(in srgb, var(--paper) 90%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: var(--rule);
  }
  .paper-jump-inner {
    display: flex;
    gap: var(--space-6);
    padding-block: var(--space-3);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .paper-jump-inner::-webkit-scrollbar { display: none; }
  .paper-jump a {
    color: var(--ink-2);
    text-decoration: none;
    white-space: nowrap;
    font-size: var(--text-sm);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .paper-jump a:hover { color: var(--signal); }
  .paper-jump a.is-active { color: var(--signal); font-weight: 600; }

  /* anchor targets clear both sticky bars */
  #overview, #method, #figure, #summary, #results { scroll-margin-top: 6rem; }

  .paper-head {
    padding-block: var(--space-24) var(--space-16);
    border-bottom: var(--rule);
  }

  .breadcrumb { display: block; margin-bottom: var(--space-12); }
  .breadcrumb a { color: var(--ink-3); text-decoration: none; }
  .breadcrumb a:hover { color: var(--signal); }

  .paper-meta {
    display: flex;
    gap: var(--space-4);
    align-items: baseline;
    margin-bottom: var(--space-6);
  }

  .status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-1);
  }

  .status--presented { background: var(--verified-wash); color: var(--verified); }
  .status--review { background: var(--signal-wash); color: var(--signal-deep); }
  .status--working { background: var(--paper-recessed); color: var(--ink-2); }

  .paper-title {
    font-size: var(--text-xl);
    font-weight: 460;
    max-width: 30ch;
    margin-bottom: var(--space-6);
  }

  .paper-authors { color: var(--ink-3); margin-bottom: var(--space-4); }

  .paper-oneliner {
    font-size: var(--text-md);
    line-height: var(--leading-snug);
    color: var(--ink-2);
    max-width: 52ch;
  }

  .paper-links {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-8);
  }

  .btn {
    display: inline-block;
    padding: var(--space-3) var(--space-6);
    border: 1px solid var(--hairline-strong);
    border-radius: var(--radius-2);
    color: var(--ink);
    text-decoration: none;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  .btn:hover { border-color: var(--signal); color: var(--signal); }

  .section-eyebrow {
    color: var(--signal);
    display: block;
    margin-bottom: var(--space-8);
  }

  .plain {
    padding-block: var(--space-16);
    border-bottom: var(--rule);
  }

  .plain-text {
    font-size: var(--text-md);
    line-height: var(--leading-snug);
    max-width: 62ch;
    padding: var(--space-6) var(--space-8);
    background: var(--paper-recessed);
    border-left: 2px solid var(--signal);
    border-radius: var(--radius-1);
    color: var(--ink);
  }

  .method { padding-block: var(--space-24); border-bottom: var(--rule); }

  .method-grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: var(--space-8);
    align-items: start;
  }

  .method-figs {
    display: grid;
    gap: var(--space-8);
  }

  @media (max-width: 860px) {
    .method-grid { grid-template-columns: 1fr; }
  }

  .onefig {
    padding-block: var(--space-24);
    border-bottom: var(--rule);
  }

  .onefig > div { max-width: 60rem; }

  .five { padding-block: var(--space-24); border-bottom: var(--rule); }

  .five-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12) var(--space-16);
  }

  .five-block {
    display: grid;
    grid-template-rows: auto auto 1fr;
    gap: var(--space-3);
    align-content: start;
  }

  .five-index { color: var(--signal); }

  .five-label {
    font-size: var(--text-md);
    font-style: italic;
    font-weight: 500;
  }

  .five-text { color: var(--ink-2); }

  .results { padding-block: var(--space-24); border-bottom: var(--rule); }

  .results-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: var(--space-6);
  }

  .results-grid li {
    display: grid;
    gap: var(--space-2);
    padding: var(--space-6);
    border: var(--rule-strong);
    border-radius: var(--radius-2);
    background: var(--paper-raised);
  }

  .result-value {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    color: var(--signal);
    letter-spacing: -0.02em;
  }

  .result-label {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--ink-2);
  }

  .caveat {
    margin-top: var(--space-8);
    padding: var(--space-4) var(--space-6);
    background: var(--paper-recessed);
    border-left: 2px solid var(--hairline-strong);
    color: var(--ink-2);
    max-width: 70ch;
  }

  .caveat-tag { display: block; margin-bottom: var(--space-2); }

  .cite { padding-block: var(--space-24); border-bottom: var(--rule); }

  .cite-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
  }

  .theme-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .cite-note { color: var(--ink-2); }

  .related { padding-block: var(--space-24); }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 2px solid var(--ink);
  }

  .related-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    padding-block: var(--space-4);
    border-bottom: var(--rule);
    text-decoration: none;
    color: var(--ink);
  }

  .related-link:hover .related-title { color: var(--signal); }

  .related-title {
    font-size: var(--text-md);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .related-status { color: var(--ink-3); }

  .footer { border-top: var(--rule); background: var(--paper-recessed); }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-8);
  }

  .back { color: var(--signal); text-decoration: none; }

  @media (max-width: 720px) {
    .five-list { grid-template-columns: 1fr; }
    .cite-grid { grid-template-columns: 1fr; gap: var(--space-12); }
  }
</style>
